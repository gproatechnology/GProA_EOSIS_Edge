# GProA EDGE - Dockerfile Unificado (Todo en Uno)
# Para Render: Un solo Web Service que incluye Backend + Frontend + Nginx
# Este Dockerfile crea una imagen con:
# - Backend FastAPI (Python) en puerto 8000
# - Frontend React built (archivos estáticos)
# - Nginx como proxy inverso (puerto 80)
# Variables de entorno soportadas: DEMO_MODE, MONGO_URL, OPENAI_API_KEY, etc.

# ============================================
# Stage 1: Backend (Python + FastAPI)
# ============================================
FROM python:3.12-slim AS backend-builder

WORKDIR /app/backend

# Instalar dependencias del sistema
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Copiar requirements e instalar
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copiar código del backend
COPY backend/ /app/backend/

# Crear directorio para SQLite
RUN mkdir -p /app/backend/data

# ============================================
# Stage 2: Frontend (Node + React Build)
# ============================================
FROM node:18-alpine AS frontend-builder

WORKDIR /app/frontend

# Copiar package files
COPY frontend/package*.json ./
RUN npm ci --only=production

# Copiar código fuente
COPY frontend/ ./

# Build de producción
RUN npm run build

# ============================================
# Stage 3: Production - Nginx Reverse Proxy
# ============================================
FROM nginx:alpine

# Copiar configuración personalizada de Nginx (si existe)
# Si no existe, usa la configuración por defecto que sirve estáticos y proxy
COPY --from=backend-builder /app/backend /app/backend
COPY --from=frontend-builder /app/frontend/build /usr/share/nginx/html

# Custom Nginx config que enruta /api → backend, / → frontend
COPY nginx/nginx.conf /etc/nginx/conf.d/default.conf

# Exponer puerto 80 (HTTP)
EXPOSE 80

# Comando: Nginx en foreground
CMD ["nginx", "-g", "daemon off;"]
