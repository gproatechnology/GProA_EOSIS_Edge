# Environment Variables for GProA EDGE
# Copy this file to .env and fill in your actual values

# OpenAI API Key (get from https://platform.openai.com/api-keys)
# You can also use EMERGENT_LLM_KEY if you have one from emergent.sh
OPENAI_API_KEY=sk-your-openai-api-key-here

# Alternative: Emergent Universal Key (if using emergent.sh)
# EMERGENT_LLM_KEY=sk-your-emergent-key-here

# MongoDB Connection
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Database Name
DB_NAME=gproa_edge

# CORS Origins (comma-separated, no spaces)
# For development: http://localhost:3000
# For Render: https://gproa-edge-frontend.onrender.com
CORS_ORIGINS=*

# Frontend URL (optional, for reference)
FRONTEND_URL=
