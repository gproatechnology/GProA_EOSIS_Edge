# GProA EDGE - Environment Variables
# DEFAULT VALUES FOR DEMO MODE (no API keys required)
# Copy this to .env and override as needed

# ── OpenAI (optional - uses mock responses if not set) ──────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ── Database ────────────────────────────────────────────────────────────────
# If MONGO_URL is set → uses MongoDB (requires Atlas connection string)
# If MONGO_URL is EMPTY → uses SQLite file (./data/gproa_edge.db)
MONGO_URL=
DB_NAME=gproa_edge

# ── CORS ────────────────────────────────────────────────────────────────────
# For local dev: http://localhost:3000
# For Render: https://gproa-edge-frontend.onrender.com
CORS_ORIGINS=*

# ── Misc ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=
# DEMO_MODE=true enables mock AI responses when no API key
DEMO_MODE=false
